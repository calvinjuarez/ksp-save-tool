{
	"name": "ksp-save-tool",
	"version": "0.0.0",
	"description": "Web app to explore Kerbal Space Program save files (Vue 3, Vite, PWA)",
	"private": true,
	"license": "UNLICENSED",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/calvinjuarez/ksp-save-tool.git"
	},
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"icons": "node scripts/rasterize-app-icon.mjs",
		"preview": "vite preview",
		"test": "vitest",
		"test:run": "vitest run && npm run verify:icons",
		"verify:icons": "node scripts/verify-app-icon.mjs"
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"devDependencies": {
		"@vitejs/plugin-vue": "^6.0.4",
		"happy-dom": "^20.1.0",
		"sharp": "^0.34.5",
		"vite": "^8.0.7",
		"vite-plugin-pwa": "^1.2.0",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"ksp-confignode": "workspace:*",
		"bootstrap": "^5.3.8",
		"pinia": "^3.0.4",
		"vue": "^3.5.28",
		"vue-router": "^5.0.2"
	},
	"overrides": {
		"serialize-javascript": "^7.0.3",
		"vite-plugin-pwa": {
			"vite": "$vite"
		}
	}
}
